# Copy to ".env" (never commit .env). DATABASE_URL required for API + provisioning.
DATABASE_URL=sqlite+pysqlite:///./arctis_dev.db

# Filled by: python scripts/provision_local_dev_tenant.py (after migrations)
ARCTIS_API_URL=http://localhost:8000
ARCTIS_API_KEY=
ARCTIS_TENANT_ID=
ARCTIS_WORKFLOW_ID=
